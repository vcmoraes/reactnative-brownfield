<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BrownfieldHostTest" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/host_primary</item>
        <item name="colorOnPrimary">@color/host_on_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Launcher / tela nativa: sem ActionBar do tema; Toolbar no layout + edge-to-edge. -->
    <style name="Theme.BrownfieldHostTest.Main" parent="Theme.BrownfieldHostTest">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.BrownfieldHostTest.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
